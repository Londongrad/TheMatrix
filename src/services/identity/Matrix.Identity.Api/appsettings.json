{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GeoLocation": {
    "Enabled": false,
    "TimeoutSeconds": 10,
    "EndpointTemplate": "https://ipapi.co/{ip}/json/"
  },
  "FrontendLinks": {
    "BaseUrl": "http://localhost:5173",
    "ConfirmEmailPath": "/confirm-email",
    "ResetPasswordPath": "/reset-password"
  },
  "Email": {
    "DeliveryMode": "LogOnly",
    "FromEmail": "noreply@example.com",
    "FromName": "The Matrix",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "UseSsl": true
  },
  "OneTimeTokens": {
    "EmailConfirmationLifetimeMinutes": 1440,
    "PasswordResetLifetimeMinutes": 60
  },
  "Outbox": {
    "BatchSize": 50,
    "PollIntervalSeconds": 2,
    "LeaseTtlSeconds": 30,
    "FailureBackoffMaxSeconds": 300,
    "ProcessedRetentionSeconds": 0,
    "CleanupBatchSize": 500
  },
  "RefreshTokenCleanup": {
    "CleanupEnabled": true,
    "PollIntervalSeconds": 300,
    "BatchSize": 500,
    "RevokedRetentionHours": 24,
    "ExpiredRetentionHours": 24
  },
  "ExternalJwt": {
    "Issuer": "",
    "Audience": "",
    "SigningKey": "",
    "AccessTokenLifetimeMinutes": "",
    "RefreshTokenLifetimeDays": "",
    "ShortRefreshTokenLifetimeHours": ""
  },
  "IdentityInternal": {
    "ApiKey": ""
  },
  "ConnectionStrings": {
    "IdentityDb": ""
  },
  "RabbitMq": {
    "Host": "",
    "Port": "",
    "VirtualHost": "",
    "Username": "",
    "Password": ""
  }
}
